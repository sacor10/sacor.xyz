{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "verbatimModuleSyntax": true,
    "types": ["node", "vite/client"]
  },
  "include": ["src", "netlify/functions", "tests", "scripts"]
}

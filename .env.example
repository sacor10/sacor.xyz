FINNHUB_API_KEY=your_finnhub_api_key_here

# Instagram Downloader frontend API target.
# Run the dedicated API with: npm --prefix services/instagram-downloader run dev
VITE_INSTAGRAM_DOWNLOADER_API_URL=http://localhost:8787

# Google Sign-In (account system + Travel Plans)
# Create an OAuth 2.0 Web Client ID in Google Cloud Console.
# Authorized JS origins: http://localhost:8888 and https://sacor.xyz
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Travel Plan stop search ("FIND A PLACE") — Places API (New), server-side only.
# Use a dedicated key: API restriction = Places API (New); application restriction = None (not HTTP referrers).
GOOGLE_PLACES_API_KEY=

# Comma-separated Google account emails that can create and manage Travel Plans.
TRAVEL_PLAN_EMAILS=

# Resend invite emails for Travel Plan sharing.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SITE_URL=http://localhost:8888

# Legacy fallback for a single account. Prefer TRAVEL_PLAN_EMAILS.
OWNER_EMAIL=

# 32+ random bytes used to HMAC-sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Instagram Downloader API service.
# SITE_ORIGINS is a comma-separated CORS allowlist.
SITE_ORIGINS=http://localhost:5173,http://localhost:8888,https://sacor.xyz,https://www.sacor.xyz
PORT=8787
MAX_ITEMS=20
EXTRACT_TIMEOUT_MS=30000
MEDIA_TIMEOUT_MS=30000
MAX_VIDEO_BYTES=524288000

FINNHUB_API_KEY=your_finnhub_api_key_here

# Turso database for the visitor counter (netlify/functions/hit.mjs).
# TURSO_DATABASE_URL is the libsql://... URL: turso db show <db-name> --url
# TURSO_AUTH_TOKEN is a bearer token:        turso db tokens create <db-name>
# Both must also be set in the Netlify UI for production.
# When unset locally, the function falls back to a local file DB (./.data/sacor.db).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Instagram Downloader frontend API target.
# Run the dedicated API with: npm --prefix services/instagram-downloader run dev
VITE_INSTAGRAM_DOWNLOADER_API_URL=http://localhost:8787

# X Downloader: served by netlify/functions/x-download.mjs — no env var needed.
# The legacy local Express service in services/x-downloader/ still works if you
# want to run it; the deployed site no longer uses it.

# Google Sign-In (account system + Travel Plans)
# Create an OAuth 2.0 Web Client ID in Google Cloud Console.
# Authorized JS origins: http://localhost:8888 and https://sacor.xyz
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Travel Plan stop search ("FIND A PLACE") — Places API (New), server-side only.
# Use a dedicated key: API restriction = Places API (New); application restriction = None (not HTTP referrers).
GOOGLE_PLACES_API_KEY=

# Optional comma-separated Google account emails marked as site owners.
# Any signed-in Google account can create and manage its own Travel Plans.
# Owners are also super-admins of the Stumble moderation queue: they can review
# submissions AND manage the moderator roster. Additional moderators (review-only)
# are added in-app at /stumble/moderation and persisted in Netlify Blobs, so no
# redeploy is needed to grant or revoke moderation access.
TRAVEL_PLAN_EMAILS=

# Resend invite emails for Travel Plan sharing.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SITE_URL=http://localhost:8888

# Legacy owner marker fallback for a single account. Prefer TRAVEL_PLAN_EMAILS.
OWNER_EMAIL=

# 32+ random bytes used to HMAC-sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# "What's That Song" (/song-id) — netlify/functions/song-identify.mts.
# Requires Google sign-in: SESSION_SECRET and the Google client IDs above must be set.
# The default provider is the free unofficial Shazam endpoint — no key, no signup,
# nothing to configure. It has no SLA and could break or block serverless IPs;
# if that happens, set SONG_ID_PROVIDER=audd and provide AUDD_API_TOKEN (paid,
# https://dashboard.audd.io). The token is server-side only: must NOT be
# VITE_-prefixed or it ships in the client bundle. Netlify UI for production.
SONG_ID_PROVIDER=shazam
AUDD_API_TOKEN=
# Kill switch: set to "true" to disable the endpoint (e.g. if the quota is abused).
SONG_ID_DISABLED=
# Max provider calls per user lookup (the slowed-audio speed sweep). 1..7.
SONG_ID_MAX_SWEEP_ATTEMPTS=4
# Global provider-call budget per calendar month = the cost ceiling.
# 1000 calls ≈ $5/month after the free tier; endpoint returns 503 once spent.
SONG_ID_MONTHLY_CALL_CAP=1000
# Per-signed-in-user lookups per hour (each lookup may use several provider calls).
SONG_ID_RATE_LIMIT_PER_HOUR=10

# Downloader API services.
# SITE_ORIGINS is a comma-separated CORS allowlist.
# The Instagram API defaults to PORT=8787; the X API defaults to PORT=8788.
SITE_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8888,http://127.0.0.1:8888,http://localhost:4173,http://127.0.0.1:4173,https://sacor.xyz,https://www.sacor.xyz
PORT=8787
MAX_ITEMS=20
EXTRACT_TIMEOUT_MS=30000
MEDIA_TIMEOUT_MS=30000
MAX_VIDEO_BYTES=524288000
